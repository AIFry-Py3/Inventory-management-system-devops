pipeline {
    agent any
    stages {
        stage('Connect to GitHub') {
            steps {
                // Use the git step to clone your repository
                git url: 'https://github.com',
                    branch: 'main',
                    credentialsId: 'github-creds' 
            }
        }
        stage('Build') {
            steps {
                echo 'Source code connected and pulled successfully!'
            }
        }
    }
}
