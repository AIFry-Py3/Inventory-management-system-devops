pipeline {
    agent {
        docker {
            image 'python:3.11-slim'
            args '--user root -v /var/run/docker.sock:/var/run/docker.sock -v /root/.docker:/root/.docker'
        }
    }

    environment {
        APP_NAME = 'stockseva-streamlit'
        DOCKER_REGISTRY = 'sharanya5629'              // ← Your Docker Hub username
        IMAGE_TAG = "${DOCKER_REGISTRY}/${APP_NAME}:${BUILD_NUMBER}"
        LATEST_TAG = "${DOCKER_REGISTRY}/${APP_NAME}:latest"
        
        // SonarQube Configuration
        SONAR_HOST_URL = 'http://34.201.116.83:9000'  // ← Your SonarQube URL
        SONAR_PROJECT_KEY = 'stockseva-streamlit'     // ← Unique project key
        SONAR_PROJECT_NAME = 'StockSeva Streamlit App'
    }

    options {
        timeout(time: 25, unit: 'MINUTES')
        disableConcurrentBuilds()
        buildDiscarder(logRotator(numToKeepStr: '5'))
    }

    stages {
        stage('Checkout') {
            steps {
                echo '📦 Checking out source code...'
                sh 'git config --global --add safe.directory $WORKSPACE'
            }
        }

        stage('Install Dependencies') {
            steps {
                echo '📥 Installing Python dependencies...'
                sh 'pip install --upgrade pip'
                sh 'pip install -r requirements.txt'
                // Install SonarScanner CLI
                sh '''
                    curl -sSLo /tmp/sonar-scanner.zip https://binaries.sonarsource.com/Distribution/sonar-scanner-cli/sonar-scanner-cli-4.8.0.2856-linux.zip
                    unzip -q /tmp/sonar-scanner.zip -d /opt/
                    ln -sf /opt/sonar-scanner-4.8.0.2856-linux/bin/sonar-scanner /usr/local/bin/sonar-scanner
                '''
            }
        }

        stage('Run Tests') {
            steps {
                echo '🧪 Running unit tests...'
                sh 'pytest tests/ -v --tb=short'
            }
        }

        stage('SonarQube Analysis') {
            steps {
                echo '🔍 Running SonarQube static analysis...'
                withCredentials([string(credentialsId: 'sonarqube-token', variable: 'SONAR_TOKEN')]) {
                    sh '''
                        sonar-scanner \
                            -Dsonar.projectKey=${SONAR_PROJECT_KEY} \
                            -Dsonar.projectName="${SONAR_PROJECT_NAME}" \
                            -Dsonar.sources=. \
                            -Dsonar.host.url=${SONAR_HOST_URL} \
                            -Dsonar.login=${SONAR_TOKEN} \
                            -Dsonar.python.version=3.10 \
                            -Dsonar.inclusions=**/*.py \
                            -Dsonar.exclusions=**/tests/**,**/__pycache__/**,**/*.pyc \
                            -Dsonar.sourceEncoding=UTF-8
                    '''
                }
            }
        }

        stage('Build Docker Image') {
            steps {
                echo '🐳 Building Docker image...'
                sh 'docker build -t ${IMAGE_TAG} -f Dockerfile .'
                sh 'docker tag ${IMAGE_TAG} ${LATEST_TAG}'
            }
        }

        stage('Push Docker Image') {
            steps {
                echo '📤 Pushing Docker image to registry...'
                withCredentials([usernamePassword(credentialsId: 'docker-cred', usernameVariable: 'DOCKER_USER', passwordVariable: 'DOCKER_PASS')]) {
                    sh 'echo ${DOCKER_PASS} | docker login -u ${DOCKER_USER} --password-stdin'
                    sh 'docker push ${IMAGE_TAG}'
                    sh 'docker push ${LATEST_TAG}'
                }
            }
        }

        stage('Update Kubernetes Manifests') {
            steps {
                echo '🔄 Updating Kubernetes deployment manifests...'
                script {
                    // Update image tag in deployment.yaml (in this repo)
                    sh '''
                        sed -i "s|image: ${DOCKER_REGISTRY}/${APP_NAME}:.*|image: ${IMAGE_TAG}|g" deployment.yaml
                    '''
                    
                    // Optional: Push to separate GitOps repo for ArgoCD
                    // Uncomment when ready:
                    /*
                    withCredentials([string(credentialsId: 'github-token', variable: 'GITHUB_TOKEN')]) {
                        sh '''
                            git clone https://${GITHUB_TOKEN}@github.com/${GIT_USER_NAME}/${GIT_REPO_NAME}.git gitops-repo
                            cd gitops-repo
                            git config user.email "jenkins@ci.local"
                            git config user.name "Jenkins CI"
                            sed -i "s|image: ${DOCKER_REGISTRY}/${APP_NAME}:.*|image: ${IMAGE_TAG}|g" deployment.yaml
                            git add deployment.yaml
                            git commit -m "🚀 Update ${APP_NAME} to ${IMAGE_TAG} [Jenkins #${BUILD_NUMBER}]"
                            git push https://${GITHUB_TOKEN}@github.com/${GIT_USER_NAME}/${GIT_REPO_NAME}.git HEAD:main
                        '''
                    }
                    */
                }
            }
        }

        stage('Deploy to Kind Cluster') {
            steps {
                echo '🚀 Deploying to Kind Kubernetes cluster...'
                script {
                    // Ensure kubectl is available
                    sh '''
                        if ! command -v kubectl &> /dev/null; then
                            curl -LO "https://dl.k8s.io/release/$(curl -L -s https://dl.k8s.io/release/stable.txt)/bin/linux/amd64/kubectl"
                            chmod +x kubectl
                            mv kubectl /usr/local/bin/
                        fi
                    '''
                    
                    // Apply manifests
                    sh '''
                        kubectl apply -f deployment.yaml
                        kubectl apply -f service.yaml
                        kubectl apply -f secret.yaml
                    '''
                    
                    // Wait for rollout
                    sh 'kubectl rollout status deployment/${APP_NAME} --timeout=120s'
                    sh 'kubectl get pods -l app=stockseva'
                }
            }
        }

        stage('Verify Deployment') {
            steps {
                echo '✅ Verifying deployment...'
                script {
                    sh '''
                        kubectl get svc ${APP_NAME}
                        echo "🎉 Deployment complete!"
                        echo "Access via: kubectl port-forward svc/${APP_NAME} 8501:8501"
                        echo "Then visit: http://localhost:8501"
                    '''
                }
            }
        }
    }

    post {
        always {
            echo '🧹 Cleaning up...'
            sh 'docker system prune -f || true'
            sh 'rm -rf gitops-repo /tmp/sonar-scanner.zip /opt/sonar-scanner-* || true'
        }
        success {
            echo '✅ Pipeline completed successfully!'
            echo "🎉 Image: ${IMAGE_TAG} | SonarQube: ${SONAR_HOST_URL}/dashboard?id=${SONAR_PROJECT_KEY}"
        }
        failure {
            echo '❌ Pipeline failed. Check console output.'
        }
        unstable {
            echo '⚠️ Pipeline completed with warnings (e.g., SonarQube quality gate).'
        }
    }
}
