pipeline {
    agent any

    stages {
        stage('Build') {
            steps {
                sh 'docker build -t stockseva-app:${BUILD_NUMBER} .'
            }
        }

        stage('Test') {
            steps {
                sh 'pytest || exit 1'
            }
        }

        stage('Deploy') {
            steps {
                sh '''
                docker rm -f stockseva-app || true

                docker run -d \
                  --name stockseva-app \
                  --network devops-net \
                  --restart unless-stopped \
                  -p 8501:8501 \
                  -e DB_HOST=postgres-db \
                  -e DB_PORT=5432 \
                  -e DB_NAME=mydatabase \
                  -e DB_USER=myuser \
                  -e DB_PASSWORD=mysecretpassword \
                  -e REDIS_HOST=redis \
                  stockseva-app:${BUILD_NUMBER}
                '''
            }
        }
    }
}
