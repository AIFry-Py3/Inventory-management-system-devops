pipeline {
    agent any

    stages {
        stage('Run Streamlit') {
            steps {
                sh '''
                python3 -m venv venv
                . venv/bin/activate

                pip install --upgrade pip
                pip install streamlit

                nohup streamlit run app.py --server.port 8501 --server.address 0.0.0.0 &
                '''
            }
        }
    }
}
