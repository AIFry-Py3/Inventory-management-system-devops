pipeline {
    agent any

    environment {
        DB_HOST = 'postgres-db'
        DB_PORT = '5432'
        DB_NAME = 'mydatabase'
        DB_USER = 'myuser'
        DB_PASSWORD = 'mysecretpassword'

        REDIS_HOST = 'redis'
        REDIS_PORT = '6379'
    }

    stages {
        stage('Build Image') {
            steps {
                sh '''
                docker build -t stockseva-app .
                '''
            }
        }

        stage('Run App') {
            steps {
                sh '''
                docker rm -f stockseva-app || true

                docker run -d \
                  --name stockseva-app \
                  -p 8501:8501 \
                  --network devops-net \
                  -e DB_HOST=$DB_HOST \
                  -e DB_PORT=$DB_PORT \
                  -e DB_NAME=$DB_NAME \
                  -e DB_USER=$DB_USER \
                  -e DB_PASSWORD=$DB_PASSWORD \
                  -e REDIS_HOST=$REDIS_HOST \
                  -e REDIS_PORT=$REDIS_PORT \
                  stockseva-app
                '''
            }
        }
    }
}
